digraph LPP {
  label="Twelve angry men";
  labelloc=t;
  labeljust=l;
  fontname="Helvetica-Bold";
  fontsize=16;
  graph [rankdir=LR, bgcolor=white, pad=0.8,
         nodesep=0.55, ranksep=1.2, splines=ortho];
  node  [fontname=Helvetica, fontsize=10, margin="0.12,0.08"];
  edge  [fontname=Helvetica, fontsize=9];

  // ── Level clusters ───────────────────────────────────────────
  subgraph cluster_l0 {
    label="Level 0 — Object rules";
    fontsize=11; fontname=Helvetica;
    style=dashed; color="#aaaaaa"; fillcolor="#fdfdf0";
    c1 [label="c1\\nWhat does a guilty man look like", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c10 [label="c10\\nthis boy's been kicked around all his\\nlife", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c11 [label="c11\\nliving in a slum his mother dead since\\nhe was nine", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c12 [label="c12\\nHe's a tough, angry kid", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c13 [label="c13\\nwe knock'em over the head once a day,\\nevery day", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c14 [label="c14\\nEverything I've got I fought for", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c15 [label="c15\\nI worked my way through college", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c19 [label="c19\\nI've lived among'em all my life", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c2 [label="c2\\nAre we to vote on his face", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c20 [label="c20\\nI don't see any need for arguing like\\nthis", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c25 [label="c25\\nThe burden of proof is on the\\nprosecution", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c26 [label="c26\\nThat's in the Constitution. The Fifth\\nAmendment", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c3 [label="c3\\nYou sat right in court and heard the\\nsame things I did", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c36 [label="c36\\na woman who's lying in bed and can't\\nsleep wakes up and sees the kid stick\\nthe knife into his father", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c37 [label="c37\\nShe's known the kid all his life. His\\nwindow is right opposite hers", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c38 [label="c38\\nshe swore she saw him do it", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c39 [label="c39\\nyou can't trust them. You can't\\nbelieve them", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c4 [label="c4\\nYou could see it", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c40 [label="c40\\nwe looked through the windows of a\\npassing el train", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c5 [label="c5\\nHe's nineteen years old", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c6 [label="c6\\nHe knifed his own father", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    c7 [label="c7\\nFour inches into the chest", shape=box, style="filled,rounded", fillcolor="#ddeeff", penwidth=1.2];
    o1 [label="o1\\nI never saw a guiltier man in my life", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o11 [label="o11\\nI think maybe we owe him a few words  [recommended]", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o12 [label="o12\\nI never killed  [negated]", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o16 [label="o16\\nYou can't believe a word they say", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o17 [label="o17\\nSince when is dishonesty a group\\ncharacteristic", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o18 [label="o18\\nYou have no monopoly on the truth", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o19 [label="o19\\nWhat this man says is very dangerous", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o2 [label="o2\\nHe is not guilty until we say he is\\nguilty  [negated]  [obligatory]", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o20 [label="o20\\nI think we ought to be able to behave\\nlike gentlemen  [recommended]", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o21 [label="o21\\nIf we're going to discuss this case,\\nlet's discuss the facts  [recommended]", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o25 [label="o25\\nNobody has to prove otherwise;\\ninnocent until proven guilty", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o26 [label="o26\\nThe defendant doesn't have to open his\\nmouth  [obligatory]", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o29 [label="o29\\nHow can she really be sure it was the\\nkid when she saw it through the\\nwindows of a passing elevated train  [negated]", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o3 [label="o3\\nThe man's a dangerous killer", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o30 [label="o30\\nthey proved in court that you can look\\nthrough the windows of a passing el\\ntrain at night, and see what's\\nhappening on the other side", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o31 [label="o31\\nHow come you believed her? She's one\\nof them, too", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o33 [label="o33\\nI didn't see as well as they told me I\\nwould see, but I did see what happened\\non the other side", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o4 [label="o4\\nThat's old enough", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o5 [label="o5\\nI agree with you that the boy is\\nguilty", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    o6 [label="o6\\nwe should try to avoid emotionally\\ncolored arguments  [recommended]", shape=box, style="filled", fillcolor="#d5f5e3", penwidth=1.2];
    r1 [label="r1", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r10 [label="r10", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r11 [label="r11", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r12 [label="r12", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r13 [label="r13\\n[recommended]", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r14 [label="r14\\n[recommended]", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r15 [label="r15", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r16 [label="r16\\n[obligatory]", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r17 [label="r17", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r18 [label="r18\\n[negated]", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r19 [label="r19", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r2 [label="r2\\n[obligatory]\\n[negated]", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r20 [label="r20", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r3 [label="r3", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r4 [label="r4", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r5 [label="r5", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r6 [label="r6\\n[recommended]", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r7 [label="r7\\n[recommended]", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r8 [label="r8\\n[negated]", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
    r9 [label="r9", shape=ellipse, style="filled", fillcolor="#fff9c4", penwidth=1.2];
  }

  subgraph cluster_l1 {
    label="Level 1 — Preferences";
    fontsize=11; fontname=Helvetica;
    style=dashed; color="#9b59b6"; fillcolor="#fdf5ff";
    pr1 [label="pr1\\nprefer\\n« you can't trust them »", shape=diamond, style="filled", fillcolor="#ead1f5", penwidth=1.4];
  }

  subgraph cluster_l2 {
    label="Level 2 — Meta-preferences";
    fontsize=11; fontname=Helvetica;
    style=dashed; color="#6c3483"; fillcolor="#f5eeff";
  }


  // ── Arêtes ──────────────────────────────────────────────
  r1 -> o1 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c3 -> r1 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r2 -> o2 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c1 -> r2 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  c2 -> r2 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r3 -> o3 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c3 -> r3 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  c4 -> r3 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r4 -> o4 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c6 -> r4 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  c7 -> r4 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r5 -> o5 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c5 -> r5 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  c6 -> r5 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r6 -> o6 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  o5 -> r6 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r7 -> o11 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c10 -> r7 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  c11 -> r7 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  c12 -> r7 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  c13 -> r7 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r8 -> o12 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c14 -> r8 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  c15 -> r8 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r9 -> o16 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c19 -> r9 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r10 -> o17 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  o16 -> r10 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r11 -> o18 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  o17 -> r11 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r12 -> o19 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  o16 -> r12 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r13 -> o20 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c20 -> r13 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r14 -> o21 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  o20 -> r14 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r15 -> o25 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c25 -> r15 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r16 -> o26 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c26 -> r16 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r17 -> o30 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c36 -> r17 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  c37 -> r17 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  c38 -> r17 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r18 -> o29 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c36 -> r18 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r19 -> o31 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c39 -> r19 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  o30 -> r19 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  r20 -> o33 [label="effect", color="#1a7a40", style=solid, arrowhead=normal, penwidth=1.3];
  c40 -> r20 [label="condition", color="#2e86c1", style=solid, arrowhead=normal, penwidth=1.3];
  pr1 -> r2 [label="winner", color="#7d3c98", style=dashed, arrowhead=open, penwidth=2.0];
  pr1 -> r9 [label="loser", color="#c0392b", style=dashed, arrowhead=open, penwidth=2.0];
  c39 -> pr1 [label="when", color="#e67e22", style=dotted, arrowhead=normal, penwidth=1.3];

  subgraph cluster_legend {
    label="Légende LPP/GORGIAS";
    fontsize=13;
    fontname="Helvetica-Bold";
    style="rounded,filled";
    fillcolor="#fafafa";
    color="#999999";
    margin=18;

    subgraph cluster_leg_levels {
      label="Niveaux LPP";
      fontsize=11;
      fontname=Helvetica;
      style=rounded;
      color="#cccccc";
      margin=12;

      leg_ctx  [label="c1\nContext\n(condition)",
                shape=box, style="rounded,filled",
                fillcolor="#ddeeff", fontsize=9, fontname=Helvetica, width=1.5];
      leg_opt  [label="o1\nOption\n(conclusion)",
                shape=box, style="filled",
                fillcolor="#d5f5e3", fontsize=9, fontname=Helvetica, width=1.5];
      leg_rule [label="r1\nrule\n(Level 0)",
                shape=ellipse, style="filled",
                fillcolor="#fff9c4", fontsize=9, fontname=Helvetica, width=1.5];
      leg_pref [label="pr1\nprefer\n(Level 1)",
                shape=diamond, style="filled",
                fillcolor="#ead1f5", fontsize=9, fontname=Helvetica, width=1.5];
      leg_meta [label="pp1\nmeta_prefer\n(Level 2)",
                shape=diamond, style="filled",
                fillcolor="#d2b4de", fontsize=9, fontname=Helvetica, width=1.5];
      leg_ctx -> leg_opt -> leg_rule -> leg_pref -> leg_meta [style=invis];
    }

    subgraph cluster_leg_edges {
      label="Types d'arêtes";
      fontsize=11;
      fontname=Helvetica;
      style=rounded;
      color="#cccccc";
      margin=12;

      le_s1 [label="", shape=none, width=0.01, height=0.01];
      le_d1 [label="", shape=none, width=0.01, height=0.01];
      le_s2 [label="", shape=none, width=0.01, height=0.01];
      le_d2 [label="", shape=none, width=0.01, height=0.01];
      le_s3 [label="", shape=none, width=0.01, height=0.01];
      le_d3 [label="", shape=none, width=0.01, height=0.01];
      le_s4 [label="", shape=none, width=0.01, height=0.01];
      le_d4 [label="", shape=none, width=0.01, height=0.01];
      le_s5 [label="", shape=none, width=0.01, height=0.01];
      le_d5 [label="", shape=none, width=0.01, height=0.01];

      le_s1 -> le_d1 [label="condition", style=solid,  color="#2e86c1",
                       fontsize=9, fontname=Helvetica, arrowhead=normal];
      le_s2 -> le_d2 [label="effect",    style=solid,  color="#1a7a40",
                       fontsize=9, fontname=Helvetica, arrowhead=normal];
      le_s3 -> le_d3 [label="winner",    style=dashed, color="#7d3c98",
                       fontsize=9, fontname=Helvetica, arrowhead=open];
      le_s4 -> le_d4 [label="loser",     style=dashed, color="#c0392b",
                       fontsize=9, fontname=Helvetica, arrowhead=open];
      le_s5 -> le_d5 [label="when",      style=dotted, color="#e67e22",
                       fontsize=9, fontname=Helvetica, arrowhead=normal];

      le_s1 -> le_s2 -> le_s3 -> le_s4 -> le_s5 [style=invis];
      le_d1 -> le_d2 -> le_d3 -> le_d4 -> le_d5 [style=invis];
    }

    subgraph cluster_leg_attrs {
      label="Attributs";
      fontsize=11;
      fontname=Helvetica;
      style=rounded;
      color="#cccccc";
      margin=12;

      la1 [label="[implicit]\nCondition inventée\n(non présente dans\nle texte source)",
           shape=note, style=filled, fillcolor="#fff3cd",
           fontsize=8, fontname=Helvetica, width=1.8];
      la2 [label="[negated]\nProposition\nsémantiquement\nniée",
           shape=note, style=filled, fillcolor="#fde8e8",
           fontsize=8, fontname=Helvetica, width=1.8];
      la3 [label="[obligatory]\n[permitted]\n[recommended]\n[default]\nModalité déontique\nde l'Option",
           shape=note, style=filled, fillcolor="#e8f8e8",
           fontsize=8, fontname=Helvetica, width=1.8];
      la1 -> la2 -> la3 [style=invis];
    }
  }

}
